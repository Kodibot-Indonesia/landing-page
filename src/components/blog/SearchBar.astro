---
interface Props {
  placeholder?: string;
  currentValue?: string;
}

const { placeholder = "Search articles...", currentValue = "" } = Astro.props;
---

<div class="relative">
  <input
    type="text"
    id="blog-search"
    value={currentValue}
    placeholder={placeholder}
    class="w-full px-4 py-3 pl-12 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#F9DB2B] focus:border-transparent transition-all"
  />
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
    />
  </svg>
  <button
    type="button"
    id="search-clear"
    class={`absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 hover:text-gray-600 ${currentValue ? '' : 'hidden'}`}
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</div>

<script>
  const searchInput = document.getElementById('blog-search') as HTMLInputElement;
  const clearBtn = document.getElementById('search-clear');
  const blogCards = document.querySelectorAll('[data-blog-card]');
  const noResults = document.getElementById('no-results');

  function filterPosts(query: string) {
    const normalizedQuery = query.toLowerCase().trim();
    let visibleCount = 0;

    blogCards.forEach((card) => {
      const title = card.getAttribute('data-title')?.toLowerCase() || '';
      const description = card.getAttribute('data-description')?.toLowerCase() || '';
      const category = card.getAttribute('data-category')?.toLowerCase() || '';
      const tags = card.getAttribute('data-tags')?.toLowerCase() || '';

      const matches = normalizedQuery === '' ||
        title.includes(normalizedQuery) ||
        description.includes(normalizedQuery) ||
        category.includes(normalizedQuery) ||
        tags.includes(normalizedQuery);

      if (matches) {
        (card as HTMLElement).style.display = '';
        visibleCount++;
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });

    if (noResults) {
      noResults.classList.toggle('hidden', visibleCount > 0 || normalizedQuery === '');
    }

    if (clearBtn) {
      clearBtn.classList.toggle('hidden', normalizedQuery === '');
    }
  }

  searchInput?.addEventListener('input', (e) => {
    const value = (e.target as HTMLInputElement).value;
    filterPosts(value);

    // Update URL without reload
    const url = new URL(window.location.href);
    if (value) {
      url.searchParams.set('q', value);
    } else {
      url.searchParams.delete('q');
    }
    window.history.replaceState({}, '', url.toString());
  });

  clearBtn?.addEventListener('click', () => {
    if (searchInput) {
      searchInput.value = '';
      filterPosts('');
      searchInput.focus();
    }
  });
</script>
