---
interface Props {
  categories: string[];
  currentCategory?: string;
  allLabel?: string;
  locale: string;
}

const { categories, currentCategory = '', allLabel = 'All', locale } = Astro.props;

const blogUrl = locale === 'en' ? '/blog' : `/${locale}/blog`;
---

<div class="flex flex-wrap gap-2">
  <a
    href={blogUrl}
    class={`px-4 py-2 rounded-full text-sm font-medium transition-all ${
      currentCategory === ''
        ? 'bg-[#F9DB2B] text-[#2D2D2D]'
        : 'bg-white text-gray-600 hover:bg-gray-100'
    }`}
  >
    {allLabel}
  </a>
  {categories.map((category) => {
    const categoryUrl = `${blogUrl}?category=${encodeURIComponent(category)}`;
    return (
      <a
        href={categoryUrl}
        class={`px-4 py-2 rounded-full text-sm font-medium transition-all ${
          currentCategory === category
            ? 'bg-[#F9DB2B] text-[#2D2D2D]'
            : 'bg-white text-gray-600 hover:bg-gray-100'
        }`}
      >
        {category}
      </a>
    );
  })}
</div>
