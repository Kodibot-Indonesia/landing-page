---
import { Gamepad2, Cpu, Lightbulb, Medal } from '@lucide/astro';
import { m } from '../../paraglide/messages.js';
import kidCodingImg from '../../assets/images/kid-learning-coding.jpg';
---

<section class="py-24 bg-[#E18914] text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl lg:text-4xl font-bold font-sans mb-6 leading-tight">
          {m.outcome_title()}
        </h2>
        <div class="space-y-4">
          <div class="flex items-start gap-4 p-4 rounded-xl bg-white/10 backdrop-blur-sm">
            <Gamepad2 size={32} class="text-[#F9DB2B] shrink-0" />
            <div>
              <h4 class="font-bold text-lg mb-1">{m.outcome_1_title()}</h4>
              <p class="text-white/80">{m.outcome_1_desc()}</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl bg-white/10 backdrop-blur-sm">
            <Cpu size={32} class="text-[#1D8536] shrink-0" />
            <div>
              <h4 class="font-bold text-lg mb-1">{m.outcome_2_title()}</h4>
              <p class="text-white/80">{m.outcome_2_desc()}</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl bg-white/10 backdrop-blur-sm">
            <Lightbulb size={32} class="text-white shrink-0" />
            <div>
              <h4 class="font-bold text-lg mb-1">{m.outcome_3_title()}</h4>
              <p class="text-white/80">{m.outcome_3_desc()}</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl bg-white/10 backdrop-blur-sm">
            <Medal size={32} class="text-[#F9DB2B] shrink-0" />
            <div>
              <h4 class="font-bold text-lg mb-1">{m.outcome_4_title()}</h4>
              <p class="text-white/80">{m.outcome_4_desc()}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="relative flex justify-center">
        <img
          src={kidCodingImg.src}
          alt="Happy child learning coding and programming skills on laptop with parent supervision"
          width={kidCodingImg.width}
          height={kidCodingImg.height}
          loading="lazy"
          class="rounded-3xl shadow-2xl rotate-3 scale-105 border-4 border-white"
        />
      </div>
    </div>
  </div>
</section>
