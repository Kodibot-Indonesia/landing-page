---
import { CheckCircle2, XCircle } from "@lucide/astro";
import { m } from "../../paraglide/messages.js";

const rows = [
  { feature: m.comparison_r1(), youtube: false, offline: true, kodibot: true },
  { feature: m.comparison_r2(), youtube: true, offline: false, kodibot: true },
  { feature: m.comparison_r3(), youtube: false, offline: false, kodibot: true },
  { feature: m.comparison_r4(), youtube: true, offline: false, kodibot: true },
  { feature: m.comparison_r5(), youtube: " Gratis", offline: " Rp 500k-2jt/bln", kodibot: " Lifetime" },
];
---

<section class="py-20 lg:py-28 bg-[#F3F4F6]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-2xl lg:text-3xl font-bold text-[#2D2D2D] font-sans mb-4">
        {m.comparison_title()}
      </h2>
      <p class="text-[#6B7280]">
        {m.comparison_subtitle()}
      </p>
    </div>

    <!-- Comparison Table -->
    <div class="overflow-x-auto rounded-3xl shadow-xl border border-gray-200 bg-white">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr>
            <th class="p-6 bg-gray-50 border-b border-r border-gray-200 text-[#2D2D2D] font-bold w-1/4">
              {m.comparison_col1()}
            </th>
            <th class="p-6 border-b border-r border-gray-200 text-gray-500 font-bold text-center w-1/4 bg-gray-50">
              {m.comparison_col2()}
            </th>
            <th class="p-6 border-b border-r border-gray-200 text-gray-500 font-bold text-center w-1/4 bg-gray-50">
              {m.comparison_col3()}
            </th>
            <th class="p-6 border-b border-[#E18914] bg-[#E18914]/10 text-[#E18914] font-bold text-center w-1/4 text-lg">
              {m.comparison_col4()}
            </th>
          </tr>
        </thead>
        <tbody class="text-sm md:text-base">
          {rows.map((row, i) => (
            <tr>
              <td class="p-6 border-b border-r border-gray-200 font-medium">
                {row.feature}
              </td>
              <td class="p-6 border-b border-r border-gray-200 text-center">
                {typeof row.youtube === "boolean" ? (
                  row.youtube ? (
                    <CheckCircle2 size={20} class="mx-auto inline text-green-500" />
                  ) : (
                    <XCircle size={20} class="mx-auto inline text-red-500" />
                  )
                ) : (
                  <span class="text-gray-500 text-xs">{row.youtube}</span>
                )}
              </td>
              <td class="p-6 border-b border-r border-gray-200 text-center">
                {typeof row.offline === "boolean" ? (
                  row.offline ? (
                    <CheckCircle2 size={20} class="mx-auto inline text-green-500" />
                  ) : (
                    <XCircle size={20} class="mx-auto inline text-red-500" />
                  )
                ) : (
                  <span class="text-gray-500 text-xs">{row.offline}</span>
                )}
              </td>
              <td class={`p-6 border-b bg-[#E18914]/5 text-center ${i === rows.length - 1 ? "rounded-br-3xl" : ""}`}>
                {typeof row.kodibot === "boolean" ? (
                  row.kodibot ? (
                    <CheckCircle2 size={24} class="mx-auto inline text-[#1D8536]" />
                  ) : (
                    <XCircle size={24} class="mx-auto inline text-gray-400" />
                  )
                ) : (
                  <span class="text-[#E18914] font-extrabold">{row.kodibot}</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
