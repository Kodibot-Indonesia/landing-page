---
import { Youtube, MonitorX, XCircle } from '@lucide/astro';
import { m } from '../../paraglide/messages.js';
---

<section class="py-24 bg-[#F3F4F6]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl lg:text-4xl font-bold text-[#2D2D2D] font-sans mb-12">
      {m.problem_title()}
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white p-6 rounded-2xl flex flex-col items-center text-center shadow-sm">
        <div class="w-14 h-14 bg-red-50 rounded-full flex items-center justify-center mb-4">
          <Youtube size={28} class="text-red-500" />
        </div>
        <h3 class="font-bold text-[#2D2D2D] mb-2">{m.problem_item1_title()}</h3>
        <p class="text-[#6B7280] text-sm">{m.problem_item1_desc()}</p>
      </div>

      <div class="bg-white p-6 rounded-2xl flex flex-col items-center text-center shadow-sm">
        <div class="w-14 h-14 bg-orange-50 rounded-full flex items-center justify-center mb-4">
          <MonitorX size={28} class="text-[#E18914]" />
        </div>
        <h3 class="font-bold text-[#2D2D2D] mb-2">{m.problem_item2_title()}</h3>
        <p class="text-[#6B7280] text-sm">{m.problem_item2_desc()}</p>
      </div>

      <div class="bg-white p-6 rounded-2xl flex flex-col items-center text-center shadow-sm">
        <div class="w-14 h-14 bg-slate-50 rounded-full flex items-center justify-center mb-4">
          <XCircle size={28} class="text-gray-500" />
        </div>
        <h3 class="font-bold text-[#2D2D2D] mb-2">{m.problem_item3_title()}</h3>
        <p class="text-[#6B7280] text-sm">{m.problem_item3_desc()}</p>
      </div>
    </div>
  </div>
</section>
