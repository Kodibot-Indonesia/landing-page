---
import { Bot } from '@lucide/astro';
import { m } from '../../paraglide/messages.js';
---

<footer class="bg-[#2D2D2D] border-t border-[#1a1a1a] py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-2 grayscale brightness-200">
        <Bot size={24} class="text-[#E18914]" />
        <span class="text-xl font-bold text-white font-sans">Kodibot</span>
      </div>

      <div class="flex gap-6 text-gray-400 font-medium">
        <a href="/privacy" class="hover:text-white transition-colors">
          {m.footer_privacy()}
        </a>
        <a href="/terms" class="hover:text-white transition-colors">
          {m.footer_terms()}
        </a>
        <a href="mailto:hello@kodibot.com" class="hover:text-white transition-colors">
          {m.footer_contact()}
        </a>
      </div>
    </div>
    <div class="mt-8 text-center text-gray-500 text-sm">
      &copy; {new Date().getFullYear()} {m.footer_copyright()}
    </div>
  </div>
</footer>
