---
import { CheckCircle2, Star } from '@lucide/astro';
import { m } from '../../paraglide/messages.js';
import { LMS_URL } from '../../lib/config.js';

const plans = [
  {
    id: 'monthly',
    name: m.pricing_monthly_name(),
    price: m.pricing_monthly_price(),
    duration: m.pricing_monthly_duration(),
    featured: false,
  },
  {
    id: '3month',
    name: m.pricing_3month_name(),
    price: m.pricing_3month_price(),
    duration: m.pricing_3month_duration(),
    savings: m.pricing_3month_savings(),
    featured: false,
  },
  {
    id: 'lifetime',
    name: m.pricing_lifetime_name(),
    price: m.pricing_lifetime_price(),
    duration: m.pricing_lifetime_duration(),
    badge: m.pricing_lifetime_badge(),
    slot: m.pricing_lifetime_slot(),
    featured: true,
  },
];

const features = [
  m.pricing_f1(),
  m.pricing_f2(),
  m.pricing_f3(),
  m.pricing_f4(),
  m.pricing_f5(),
];
---

<section class="py-24 bg-white" id="pricing">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#1D8536]/10 border border-[#1D8536]/20 text-[#1D8536] font-medium text-sm mb-6">
        {m.pricing_trial_badge()}
      </div>
      <h2 class="text-3xl lg:text-4xl font-bold text-[#2D2D2D] font-sans mb-4">
        {m.pricing_title()}
      </h2>
      <p class="text-[#6B7280] text-lg">
        {m.pricing_subtitle()}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {plans.map((plan) => (
        <div class={`relative bg-white rounded-3xl overflow-hidden transition-transform duration-300 hover:scale-105 ${
          plan.featured 
            ? 'border-2 border-[#E18914] shadow-2xl shadow-[#E18914]/20' 
            : 'border border-gray-200 shadow-xl'
        }`}>
          {plan.badge && (
            <div class="absolute top-0 inset-x-0 bg-[#E18914] text-white text-center py-2 font-bold text-sm tracking-widest uppercase flex items-center justify-center gap-2">
              <Star size={16} class="fill-current" /> {plan.badge}
            </div>
          )}
          {plan.savings && (
            <div class="absolute top-0 inset-x-0 bg-[#1D8536] text-white text-center py-2 font-bold text-sm tracking-widest uppercase">
              {plan.savings}
            </div>
          )}

          <div class={`p-8 text-center border-b border-gray-100 ${plan.badge || plan.savings ? 'pt-12' : ''}`}>
            <h3 class="text-xl font-bold text-[#2D2D2D] mb-4">
              {plan.name}
            </h3>
            <div class="flex items-baseline justify-center gap-1">
              <span class="text-2xl font-bold text-[#6B7280]">Rp</span>
              <span class={`text-5xl font-extrabold font-sans tracking-tighter ${
                plan.featured ? 'text-[#E18914]' : 'text-[#2D2D2D]'
              }`}>{plan.price}</span>
              <span class="text-2xl font-bold text-[#6B7280]">rb</span>
            </div>
            <p class="mt-3 text-[#6B7280] font-medium">
              {plan.duration}
            </p>
            {plan.slot && (
              <p class="mt-1 text-sm text-[#E18914] font-medium">
                {plan.slot}
              </p>
            )}
          </div>

          <div class="p-8 bg-[#F3F4F6]/50">
            <ul class="space-y-3 mb-8">
              {features.map((feature) => (
                <li class="flex items-start gap-3">
                  <CheckCircle2 size={20} class="text-[#1D8536] shrink-0 mt-0.5" />
                  <span class="text-[#2D2D2D] text-sm">{feature}</span>
                </li>
              ))}
            </ul>
            <a
              href={`${LMS_URL}/register`}
              class={`w-full flex items-center justify-center py-4 rounded-2xl text-lg font-bold transition-all ${
                plan.featured
                  ? 'bg-[#E18914] text-white hover:bg-[#c9780f] shadow-lg hover:shadow-[#E18914]/40'
                  : 'bg-[#2D2D2D] text-white hover:bg-gray-800'
              }`}
            >
              {m.pricing_cta()}
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href={`${LMS_URL}/register`}
        class="text-[#E18914] font-medium hover:underline text-lg"
      >
        {m.pricing_cta_trial()} →
      </a>
    </div>
  </div>
</section>
