---
import { CheckCircle2, Star, BookOpen } from '@lucide/astro';
import { m } from '../../paraglide/messages.js';
import { LMS_URL } from '../../lib/config.js';

const foundingMember = {
  name: m.pricing_lifetime_name(),
  price: m.pricing_lifetime_price(),
  duration: m.pricing_lifetime_duration(),
  badge: m.pricing_lifetime_badge(),
  slot: m.pricing_lifetime_slot(),
};

const fmFeatures = [
  m.pricing_f1(),
  m.pricing_f2(),
  m.pricing_f3(),
  m.pricing_f4(),
  m.pricing_f5(),
  m.pricing_fm_f1(),
  m.pricing_fm_f2(),
  m.pricing_fm_f3(),
];


---

<section class="py-24 bg-white" id="pricing">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#E18914]/10 border border-[#E18914]/20 text-[#E18914] font-medium text-sm mb-6">
        <Star size={16} class="fill-current" /> {m.pricing_lifetime_badge()}
      </div>
      <h2 class="text-3xl lg:text-4xl font-bold text-[#2D2D2D] font-sans mb-4">
        {m.pricing_title()}
      </h2>
      <p class="text-[#6B7280] text-lg">
        {m.pricing_subtitle()}
      </p>
    </div>

    <!-- Founding Member Card -->
    <div class="max-w-3xl mx-auto mb-20">
      <div class="relative bg-[#1a1a2e] rounded-3xl overflow-hidden border-2 border-[#E18914] shadow-2xl shadow-[#E18914]/20">
        <!-- Badge -->
        <div class="absolute top-0 inset-x-0 bg-[#E18914] text-white text-center py-2 font-bold text-sm tracking-widest uppercase flex items-center justify-center gap-2">
          <Star size={16} class="fill-current" /> {foundingMember.badge}
        </div>

        <div class="p-8 sm:p-10 pt-14">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-8">
            <div>
              <h3 class="text-2xl sm:text-3xl font-extrabold text-white mb-1">
                {foundingMember.name}
              </h3>
              <p class="text-white/60 text-sm">{foundingMember.slot}</p>
            </div>
            <div class="text-left sm:text-right">
              <div class="flex items-baseline gap-1 justify-start sm:justify-end">
                <span class="text-lg font-bold text-white/50">Rp</span>
                <span class="text-4xl font-extrabold text-[#E18914] tracking-tighter">{foundingMember.price}</span>
                <span class="text-lg font-bold text-white/50">rb</span>
              </div>
              <p class="text-white/50 text-sm mt-1">{foundingMember.duration}</p>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-x-8 gap-y-3 mb-8">
            {fmFeatures.map((feature) => (
              <li class="flex items-start gap-3 list-none">
                <CheckCircle2 size={18} class="text-[#1D8536] shrink-0 mt-0.5" />
                <span class="text-white/90 text-sm">{feature}</span>
              </li>
            ))}
          </div>

          <a
            href={`${LMS_URL}/register`}
            class="w-full flex items-center justify-center py-4 rounded-2xl text-lg font-bold transition-all bg-[#E18914] text-white hover:bg-[#c9780f] shadow-lg hover:shadow-[#E18914]/40"
          >
            {m.pricing_cta()}
          </a>
        </div>
      </div>
    </div>

    <!-- Per-Course Section -->
    <div class="max-w-3xl mx-auto">
      <div class="relative bg-white rounded-3xl overflow-hidden border-2 border-[#1D8536] shadow-xl">
        <div class="absolute top-0 inset-x-0 bg-[#1D8536] text-white text-center py-2 font-bold text-xs tracking-widest uppercase flex items-center justify-center gap-2">
          <BookOpen size={16} /> {m.pricing_per_course_badge()}
        </div>

        <div class="p-8 sm:p-10 pt-14 text-center">
          <h3 class="text-2xl lg:text-3xl font-bold text-[#2D2D2D] font-sans mb-3">
            {m.pricing_per_course_title()}
          </h3>
          <p class="text-[#6B7280] text-lg max-w-xl mx-auto mb-8">
            {m.pricing_per_course_subtitle()}
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-10 mb-8">
            <div class="flex items-baseline gap-1">
              <span class="text-base font-bold text-[#6B7280]">{m.pricing_per_course_from()}</span>
              <span class="text-lg font-bold text-[#6B7280]">Rp</span>
              <span class="text-4xl font-extrabold text-[#2D2D2D] tracking-tighter">{m.pricing_per_course_start_price()}</span>
              <span class="text-lg font-bold text-[#6B7280]">rb</span>
              <span class="text-base font-bold text-[#6B7280]">/{m.pricing_per_course_per_course()}</span>
            </div>

            <div class="h-10 w-px bg-gray-200 hidden sm:block"></div>

            <div class="flex items-center gap-2">
              <CheckCircle2 size={20} class="text-[#1D8536] shrink-0" />
              <span class="text-[#2D2D2D] font-semibold">{m.pricing_per_course_free()}</span>
            </div>
          </div>

          <a
            href={`${LMS_URL}/register`}
            class="inline-flex items-center justify-center px-10 py-4 rounded-2xl text-lg font-bold transition-all bg-[#2D2D2D] text-white hover:bg-gray-800"
          >
            {m.pricing_cta()}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
