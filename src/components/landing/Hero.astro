---
import { ArrowRight, CheckCircle2, PlayCircle, Sparkles, Target, Check, Cpu } from '@lucide/astro';
import { m } from '../../paraglide/messages.js';
---

<section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-white">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none">
    <div class="absolute top-20 left-10 w-72 h-72 bg-[#F9DB2B] rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob" />
    <div class="absolute top-20 right-10 w-72 h-72 bg-[#1D8536] rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob [animation-delay:2000ms]" />
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <div class="text-left">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#1D8536]/10 border border-[#1D8536]/20 text-[#1D8536] font-medium text-sm mb-6 animate-fade-in-up">
          <Sparkles size={16} class="text-[#F9DB2B]" />
          <span>{m.hero_badge()}</span>
        </div>

        <h1 class="text-4xl lg:text-6xl font-bold text-[#2D2D2D] font-sans tracking-tight mb-6 animate-fade-in-up [animation-delay:100ms] leading-tight">
          {m.hero_title()}{' '}
          <span class="text-[#E18914]">{m.hero_title_accent()}</span>
        </h1>

        <p class="text-xl text-[#6B7280] mb-8 animate-fade-in-up [animation-delay:200ms] leading-relaxed">
          {m.hero_subtitle()}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up [animation-delay:300ms] mb-8">
          <a
            href="/register"
            class="w-full sm:w-auto flex items-center justify-center gap-2 bg-[#E18914] hover:bg-[#c9780f] text-white px-8 py-4 rounded-full text-lg font-bold transition-all hover:shadow-xl hover:shadow-[#E18914]/30 hover:-translate-y-1"
          >
            {m.hero_ctaRegister()} <ArrowRight size={20} />
          </a>
          <a
            href="#demo"
            class="w-full sm:w-auto flex items-center justify-center gap-2 bg-white hover:bg-[#F3F4F6] text-[#2D2D2D] border border-gray-200 px-8 py-4 rounded-full text-lg font-bold transition-all hover:-translate-y-1"
          >
            <PlayCircle size={20} class="text-[#1D8536]" /> {m.hero_ctaDemo()}
          </a>
        </div>
        <div class="flex items-center gap-4 text-sm text-[#6B7280] font-medium animate-fade-in-up [animation-delay:300ms]">
          <div class="flex items-center gap-1">
            <CheckCircle2 size={16} class="text-[#1D8536]" /> {m.hero_freeTrial()}
          </div>
          <div class="flex items-center gap-1">
            <CheckCircle2 size={16} class="text-[#1D8536]" /> {m.hero_lifetime()}
          </div>
        </div>
      </div>

      <div class="relative animate-fade-in-up [animation-delay:200ms] lg:ml-8">
        <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-2xl bg-white flex flex-col h-[400px]">
          <div class="bg-gray-100 flex items-center gap-2 px-4 py-3 border-b border-gray-200">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-amber-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
            </div>
            <div class="bg-white rounded-md flex-1 mx-4 h-6 text-xs flex items-center px-3 text-gray-400 font-mono">
              {m.hero_mockup_url()}
            </div>
          </div>
          <div class="flex-1 flex overflow-hidden">
            <div class="w-5/12 border-r border-gray-200 p-6 bg-[#F3F4F6] overflow-hidden relative">
              <div class="w-12 h-4 mb-4 bg-gray-300 rounded-full animate-pulse"></div>
              <div class="w-full h-3 mb-2 bg-[#E18914]/30 rounded-full"></div>
              <div class="w-[80%] h-3 mb-6 bg-gray-300 rounded-full"></div>
              <div class="absolute bottom-6 left-6 right-6 p-4 bg-white rounded-xl shadow-sm border border-green-100">
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-6 h-6 bg-green-100 text-green-600 rounded-full flex justify-center items-center">
                    <Check size={16} />
                  </div>
                  <h4 class="text-sm font-bold text-[#2D2D2D]">{m.hero_missionComplete()}</h4>
                </div>
                <p class="text-xs text-gray-500">{m.hero_missionDesc()}</p>
              </div>
            </div>
            <div class="w-7/12 bg-[#2D2D2D] p-4 relative flex items-center justify-center overflow-hidden">
              <div class="absolute inset-0 opacity-20 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] bg-repeat"></div>
              <div class="relative z-10 flex flex-col gap-4 items-center">
                <div class="w-48 h-12 bg-gray-100 rounded-md flex p-1 justify-center gap-1 shadow-inner">
                  {Array.from({ length: 10 }).map((_, i) => (
                    <div key={i} class="flex flex-col gap-1 justify-center">
                      <div class="w-2 h-2 rounded-full bg-gray-300 shadow-inner"></div>
                      <div class="w-2 h-2 rounded-full bg-gray-300 shadow-inner"></div>
                    </div>
                  ))}
                </div>
                <div class="w-40 h-28 bg-[#1D8536] rounded-md shadow-lg relative border border-green-700/50">
                  <div class="absolute top-2 left-2 w-8 h-8 bg-gray-300 rounded-sm"></div>
                  <div class="absolute bottom-2 left-2 w-6 h-6 bg-gray-800 rounded-full"></div>
                  <div class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-gray-800 rounded flex items-center justify-center">
                    <Cpu size={24} class="text-gray-500" />
                  </div>
                  <div class="absolute top-2 right-2 w-2 h-2 rounded-full bg-yellow-400 shadow-[0_0_10px_rgba(250,204,21,1)] animate-pulse"></div>
                </div>
                <div class="absolute left-[40%] top-[40%] w-[30%] h-1 bg-red-500 rounded-full transform -rotate-45 z-0 shadow-sm"></div>
                <div class="absolute left-[45%] top-[55%] w-[25%] h-1 bg-black rounded-full transform -rotate-12 z-0 shadow-sm"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="absolute -bottom-6 -right-6 bg-white border-2 border-[#1D8536] text-[#1D8536] px-6 py-4 rounded-2xl shadow-xl flex items-center gap-3 animate-bounce">
          <Target size={32} />
          <div>
            <div class="font-bold text-lg leading-none">{m.hero_badgeLabel()}</div>
            <div class="text-sm text-gray-500">{m.hero_badgeSublabel()}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
