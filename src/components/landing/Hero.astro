---
import { ArrowRight, CheckCircle2, PlayCircle, Sparkles, Target } from '@lucide/astro';
import { m } from '../../paraglide/messages.js';
import { LMS_URL } from '../../lib/config.js';
import scratchImg from '../../assets/screen/scratch.png';
import makecodeImg from '../../assets/screen/makecode.png';
import arduinoImg from '../../assets/screen/arduino.png';

const screenshots = [
  { src: scratchImg, alt: 'Scratch' },
  { src: makecodeImg, alt: 'MakeCode IoT' },
  { src: arduinoImg, alt: 'Arduino' },
];
const aspectRatio = scratchImg.width / scratchImg.height;
---

<section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-white">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none">
    <div class="absolute top-20 left-10 w-72 h-72 bg-[#F9DB2B] rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob" />
    <div class="absolute top-20 right-10 w-72 h-72 bg-[#1D8536] rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob [animation-delay:2000ms]" />
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <div class="text-left">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#1D8536]/10 border border-[#1D8536]/20 text-[#1D8536] font-medium text-sm mb-6 animate-fade-in-up">
          <Sparkles size={16} class="text-[#F9DB2B]" />
          <span>{m.hero_badge()}</span>
        </div>

        <h1 class="text-4xl lg:text-6xl font-bold text-[#2D2D2D] font-sans tracking-tight mb-6 animate-fade-in-up [animation-delay:100ms] leading-tight">
          {m.hero_title()}{' '}
          <span class="text-[#E18914]">{m.hero_title_accent()}</span>
        </h1>

        <p class="text-xl text-[#6B7280] mb-8 animate-fade-in-up [animation-delay:200ms] leading-relaxed">
          {m.hero_subtitle()}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up [animation-delay:300ms] mb-8">
          <a
            href={`${LMS_URL}/register`}
            class="w-full sm:w-auto flex items-center justify-center gap-2 bg-[#E18914] hover:bg-[#c9780f] text-white px-8 py-4 rounded-full text-lg font-bold transition-all hover:shadow-xl hover:shadow-[#E18914]/30 hover:-translate-y-1"
          >
            {m.hero_cta_register()} <ArrowRight size={20} />
          </a>
          <a
            href="#demo"
            class="w-full sm:w-auto flex items-center justify-center gap-2 bg-white hover:bg-[#F3F4F6] text-[#2D2D2D] border border-gray-200 px-8 py-4 rounded-full text-lg font-bold transition-all hover:-translate-y-1"
          >
            <PlayCircle size={20} class="text-[#1D8536]" /> {m.hero_cta_demo()}
          </a>
        </div>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-8 text-sm text-[#6B7280] font-medium animate-fade-in-up [animation-delay:300ms]">
          <div class="flex items-center gap-2">
            <div class="flex -space-x-2">
              <div class="w-6 h-6 rounded-full bg-[#1D8536] border-2 border-white flex items-center justify-center text-[10px] text-white font-bold">S</div>
              <div class="w-6 h-6 rounded-full bg-[#E18914] border-2 border-white flex items-center justify-center text-[10px] text-white font-bold">B</div>
              <div class="w-6 h-6 rounded-full bg-[#F9DB2B] border-2 border-white flex items-center justify-center text-[10px] text-[#2D2D2D] font-bold">D</div>
            </div>
            <span class="whitespace-nowrap">500+ students</span>
          </div>
          <div class="hidden sm:block w-px h-4 bg-gray-300"></div>
          <div class="flex items-center gap-2">
            <CheckCircle2 size={16} class="text-[#1D8536]" />
            <span>{m.hero_free_trial()}</span>
          </div>
          <div class="hidden sm:block w-px h-4 bg-gray-300"></div>
          <div class="flex items-center gap-2">
            <CheckCircle2 size={16} class="text-[#1D8536]" />
            <span>{m.hero_lifetime()}</span>
          </div>
          <div class="hidden sm:block w-px h-4 bg-gray-300"></div>
          <div class="flex items-center gap-2">
            <CheckCircle2 size={16} class="text-[#1D8536]" />
            <span>{m.hero_no_hardware()}</span>
          </div>
        </div>
      </div>

      <div class="relative animate-fade-in-up [animation-delay:200ms] lg:ml-8">
        <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-2xl bg-white flex flex-col w-full max-w-xl">
          <div class="bg-gray-100 flex items-center gap-2 px-4 py-3 border-b border-gray-200 shrink-0">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-amber-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
            </div>
            <div class="bg-white rounded-md flex-1 mx-4 h-6 text-xs flex items-center px-3 text-gray-400 font-mono">
              {m.hero_mockup_url()}
            </div>
          </div>
          <div class="relative overflow-hidden bg-white" style={`aspect-ratio: ${aspectRatio}`}>
            {screenshots.map((shot, i) => (
              <img
                src={shot.src.src}
                alt={shot.alt}
                width={shot.src.width}
                height={shot.src.height}
                class="absolute inset-0 w-full h-full object-contain hero-screenshot-img"
              />
            ))}
          </div>
        </div>
        <div class="absolute -bottom-6 -right-6 bg-white border-2 border-[#1D8536] text-[#1D8536] px-6 py-4 rounded-2xl shadow-xl flex items-center gap-3 animate-bounce">
          <Target size={32} />
          <div>
            <div class="font-bold text-lg leading-none">{m.hero_badge_label()}</div>
            <div class="text-sm text-gray-500">{m.hero_badge_sublabel()}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-screenshot-img {
    opacity: 0;
    transition: opacity 0.8s ease-in-out;
  }
  .hero-screenshot-img:nth-child(1) {
    animation: hero-cycle-1 12s infinite;
  }
  .hero-screenshot-img:nth-child(2) {
    animation: hero-cycle-2 12s infinite;
  }
  .hero-screenshot-img:nth-child(3) {
    animation: hero-cycle-3 12s infinite;
  }
  @keyframes hero-cycle-1 {
    0%, 31% { opacity: 1; }
    33%, 100% { opacity: 0; }
  }
  @keyframes hero-cycle-2 {
    0%, 31% { opacity: 0; }
    33%, 64% { opacity: 1; }
    66%, 100% { opacity: 0; }
  }
  @keyframes hero-cycle-3 {
    0%, 64% { opacity: 0; }
    66%, 100% { opacity: 1; }
  }
</style>
