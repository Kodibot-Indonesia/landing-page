---
import { Bot, CheckCircle2 } from '@lucide/astro';
import { m } from '../../paraglide/messages.js';
import { LMS_URL } from '../../lib/config.js';
import arduinoCircuitImg from '../../assets/images/arduino-circuit-board.jpg';

const features = [
  { title: m.electronics_f1_title(), desc: m.electronics_f1_desc() },
  { title: m.electronics_f2_title(), desc: m.electronics_f2_desc() },
  { title: m.electronics_f3_title(), desc: m.electronics_f3_desc() },
  { title: m.electronics_f4_title(), desc: m.electronics_f4_desc() },
];
---

<section class="py-20 lg:py-28 bg-[#2D2D2D] text-white overflow-hidden relative">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-br from-[#1D8536] to-[#E18914] opacity-10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 bg-[#E18914]/20 text-[#E18914] text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2v6l3-3"/>
          <circle cx="12" cy="14" r="4"/>
          <path d="M8 14H2M22 14h-6"/>
        </svg>
      </div>
      <h2 class="text-2xl lg:text-3xl font-bold font-sans mb-4">
        {m.simulator_title()}
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto leading-relaxed">
        {m.simulator_desc()}
      </p>
    </div>

    <!-- Main Content: Image + Features -->
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Image -->
      <div class="relative">
        <img
          src={arduinoCircuitImg.src}
          alt="Arduino Circuit"
          width={arduinoCircuitImg.width}
          height={arduinoCircuitImg.height}
          loading="lazy"
          class="rounded-3xl shadow-2xl relative z-10 border border-gray-700"
        />
        <div class="absolute top-10 -left-10 bg-white text-[#2D2D2D] p-4 rounded-2xl shadow-2xl flex items-center gap-4 animate-bounce">
          <Bot size={32} class="text-[#E18914]" />
          <div>
            <div class="font-bold">{m.simulator_mockup_label()}</div>
            <div class="text-xs text-gray-500">{m.simulator_mockup_sublabel()}</div>
          </div>
        </div>
      </div>

      <!-- Right: Features Grid -->
      <div class="space-y-4">
        {features.map((f) => (
          <div class="flex items-start gap-4 p-4 rounded-xl bg-white/5 backdrop-blur-sm hover:bg-white/10 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-[#E18914]/20 flex items-center justify-center shrink-0">
              <CheckCircle2 size={24} class="text-[#E18914]" />
            </div>
            <div>
              <h4 class="font-bold text-white mb-1">{f.title}</h4>
              <p class="text-sm text-gray-400">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="mt-12 text-center">
      <div class="inline-flex flex-col sm:flex-row items-center gap-4">
        <a
          href={`${LMS_URL}/register`}
          class="inline-flex items-center gap-2 bg-[#E18914] hover:bg-[#c9780f] text-white px-8 py-4 rounded-full text-lg font-bold transition-all shadow-[0_0_20px_rgba(225,137,20,0.4)] hover:-translate-y-1"
        >
          {m.simulator_cta()}
        </a>
        <div class="flex items-center gap-2 shrink-0">
          <CheckCircle2 size={16} class="text-[#1D8536]" />
          <span class="text-sm text-gray-400">{m.electronics_cta_free()}</span>
        </div>
      </div>
    </div>
  </div>
</section>
