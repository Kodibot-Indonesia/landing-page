---
import { Bot, CheckCircle2 } from '@lucide/astro';
import { m } from '../../paraglide/messages.js';
---

<section class="py-24 bg-[#2D2D2D] text-white overflow-hidden relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl lg:text-4xl font-bold font-sans mb-6">
          {m.simulator_title()}
        </h2>
        <p class="text-gray-400 text-lg mb-8 leading-relaxed">
          {m.simulator_desc()}
        </p>

        <ul class="space-y-4 mb-8">
          <li class="flex items-start gap-3">
            <CheckCircle2 size={24} class="text-[#1D8536] flex-shrink-0 mt-0.5" />
            <span class="text-gray-300">{m.simulator_item1()}</span>
          </li>
          <li class="flex items-start gap-3">
            <CheckCircle2 size={24} class="text-[#1D8536] flex-shrink-0 mt-0.5" />
            <span class="text-gray-300">{m.simulator_item2()}</span>
          </li>
          <li class="flex items-start gap-3">
            <CheckCircle2 size={24} class="text-[#F9DB2B] flex-shrink-0 mt-0.5" />
            <span class="text-gray-300">{m.simulator_item3()}</span>
          </li>
        </ul>
        <a
          href="/register"
          class="inline-flex items-center gap-2 bg-[#E18914] hover:bg-[#c9780f] text-white px-8 py-4 rounded-full text-lg font-bold transition-all shadow-[0_0_20px_rgba(225,137,20,0.4)] hover:-translate-y-1"
        >
          {m.simulator_cta()}
        </a>
      </div>

      <div class="relative">
        <div class="w-full aspect-square rounded-full bg-gradient-to-br from-[#1D8536] to-[#E18914] opacity-20 absolute -right-20 -bottom-20 blur-3xl"></div>
        <img
          src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&q=80"
          alt="Arduino STEM Learning"
          class="rounded-3xl shadow-2xl relative z-10 border border-gray-700"
        />
        <div class="absolute top-10 -left-10 bg-white text-[#2D2D2D] p-4 rounded-2xl shadow-2xl z-20 flex items-center gap-4 animate-bounce">
          <Bot size={32} class="text-[#E18914]" />
          <div>
            <div class="font-bold">{m.simulator_mockup_label()}</div>
            <div class="text-xs text-gray-500">{m.simulator_mockup_sublabel()}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
