---
import { m } from '../../paraglide/messages.js';
---

<section class="py-24 bg-gradient-to-b from-[#FFF8F0] to-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 bg-[#E18914]/15 text-[#E18914] text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2v6l3-3"/>
          <path d="M12 2v6l-3-3"/>
          <circle cx="12" cy="14" r="4"/>
          <path d="M8 14H2M22 14h-6"/>
        </svg>
        {m.electronics_badge()}
      </div>
      <h2 class="text-3xl sm:text-4xl font-black text-[#1A1A1A] leading-tight mb-4" style="font-family: 'Sora', 'Nunito', sans-serif; letter-spacing: -0.02em;">
        {m.electronics_title()}
      </h2>
      <p class="text-[#6B7280] text-lg max-w-2xl mx-auto leading-relaxed">
        {m.electronics_subtitle()}
      </p>
    </div>

    <!-- Feature Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-6xl mx-auto">

      <!-- Card 1: Circuit Builder -->
      <div class="group relative bg-white border border-[#E18914]/20 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div class="w-14 h-14 rounded-2xl bg-[#E18914]/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#E18914" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="4" width="16" height="16" rx="2"/>
            <path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </div>
        <h4 class="font-bold text-[#1A1A1A] text-base mb-2 leading-snug" style="font-family: 'Sora', sans-serif;">
          {m.electronics_f1_title()}
        </h4>
        <p class="text-sm text-[#6B7280] leading-relaxed mb-3">
          {m.electronics_f1_desc()}
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="text-[10px] font-semibold bg-[#E18914]/10 text-[#E18914] px-2 py-0.5 rounded-full">{m.electronics_tag_drag()}</span>
          <span class="text-[10px] font-semibold bg-[#1D8536]/10 text-[#1D8536] px-2 py-0.5 rounded-full">{m.electronics_tag_realtime()}</span>
        </div>
      </div>

      <!-- Card 2: Conductor Quiz -->
      <div class="group relative bg-white border border-[#E18914]/20 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div class="w-14 h-14 rounded-2xl bg-[#F9DB2B]/15 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#B89E00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
            <circle cx="12" cy="17" r="0.5" fill="#B89E00"/>
          </svg>
        </div>
        <h4 class="font-bold text-[#1A1A1A] text-base mb-2 leading-snug" style="font-family: 'Sora', sans-serif;">
          {m.electronics_f2_title()}
        </h4>
        <p class="text-sm text-[#6B7280] leading-relaxed mb-3">
          {m.electronics_f2_desc()}
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="text-[10px] font-semibold bg-[#F9DB2B]/15 text-[#B89E00] px-2 py-0.5 rounded-full">{m.electronics_tag_quiz()}</span>
          <span class="text-[10px] font-semibold bg-[#6366F1]/10 text-[#6366F1] px-2 py-0.5 rounded-full">{m.electronics_tag_animated()}</span>
        </div>
      </div>

      <!-- Card 3: Short Circuit Visualizer -->
      <div class="group relative bg-white border border-[#E18914]/20 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div class="w-14 h-14 rounded-2xl bg-red-50 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
        </div>
        <h4 class="font-bold text-[#1A1A1A] text-base mb-2 leading-snug" style="font-family: 'Sora', sans-serif;">
          {m.electronics_f3_title()}
        </h4>
        <p class="text-sm text-[#6B7280] leading-relaxed mb-3">
          {m.electronics_f3_desc()}
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="text-[10px] font-semibold bg-red-50 text-[#DC2626] px-2 py-0.5 rounded-full">{m.electronics_tag_safe()}</span>
          <span class="text-[10px] font-semibold bg-[#6366F1]/10 text-[#6366F1] px-2 py-0.5 rounded-full">{m.electronics_tag_visual()}</span>
        </div>
      </div>

      <!-- Card 4: LED Polarity Challenge -->
      <div class="group relative bg-white border border-[#E18914]/20 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div class="w-14 h-14 rounded-2xl bg-[#1D8536]/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1D8536" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18h6M12 2v1"/>
            <path d="M12 6a4 4 0 0 1 0 8"/>
            <path d="M12 6a4 4 0 0 0 0 8"/>
            <path d="M12 14v4"/>
            <circle cx="12" cy="10" r="1" fill="#1D8536"/>
          </svg>
        </div>
        <h4 class="font-bold text-[#1A1A1A] text-base mb-2 leading-snug" style="font-family: 'Sora', sans-serif;">
          {m.electronics_f4_title()}
        </h4>
        <p class="text-sm text-[#6B7280] leading-relaxed mb-3">
          {m.electronics_f4_desc()}
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="text-[10px] font-semibold bg-[#1D8536]/10 text-[#1D8536] px-2 py-0.5 rounded-full">{m.electronics_tag_levels()}</span>
          <span class="text-[10px] font-semibold bg-[#E18914]/10 text-[#E18914] px-2 py-0.5 rounded-full">{m.electronics_tag_game()}</span>
        </div>
      </div>

    </div>

    <!-- Bottom Highlight -->
    <div class="mt-12 max-w-3xl mx-auto">
      <div class="bg-[#1A1A1A] rounded-2xl p-6 sm:p-8 flex flex-col sm:flex-row items-center gap-6">
        <div class="shrink-0 flex items-center gap-3">
          <div class="w-12 h-12 rounded-xl bg-[#E18914] flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
              <path d="M12 8v4M12 16h.01"/>
            </svg>
          </div>
          <div class="sm:hidden">
            <div class="text-white font-bold text-sm" style="font-family: 'Sora', sans-serif;">{m.electronics_cta_title()}</div>
          </div>
        </div>
        <div class="flex-1 text-center sm:text-left">
          <div class="text-white font-bold text-sm mb-1 hidden sm:block" style="font-family: 'Sora', sans-serif;">{m.electronics_cta_title()}</div>
          <p class="text-white/70 text-sm leading-relaxed">
            {m.electronics_cta_desc()}
          </p>
        </div>
        <div class="inline-flex items-center gap-2 bg-[#1D8536] text-white text-xs font-bold px-5 py-2.5 rounded-full shrink-0">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 0l1.5 4.5H14l-3.75 2.75L11.75 12 7 8.75 2.25 12l1.5-4.75L0 4.5h4.5z"/></svg>
          {m.electronics_cta_free()}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Sora:wght@700;800;900&display=swap');
</style>
