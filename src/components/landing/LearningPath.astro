---
import { m } from '../../paraglide/messages.js';
---

<section class="py-28 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 bg-[#F9DB2B]/15 text-[#B89E00] text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-5">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M6 0l1.5 4.5H12L8.25 7.25 9.75 12 6 9.25 2.25 12l1.5-4.75L0 4.5h4.5z"/></svg>
        {m.learning_path_badge()}
      </div>
      <h2 class="text-4xl sm:text-5xl font-black text-[#1A1A1A] leading-tight mb-5" style="font-family: 'Sora', 'Nunito', sans-serif; letter-spacing: -0.02em;">
        {m.learning_path_title_v2()}
      </h2>
      <p class="text-[#6B7280] text-lg max-w-2xl mx-auto leading-relaxed">
        {m.learning_path_subtitle_v2()}
      </p>
    </div>

    <!-- ===== FOUNDATION ROW ===== -->
    <div class="mb-2">
      <!-- Foundation Label -->
      <div class="flex justify-center mb-5">
        <div class="inline-flex items-center gap-2 bg-[#1D8536]/10 text-[#1D8536] text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="6" width="12" height="7" rx="1"/>
            <path d="M7 1L1 6h12L7 1z"/>
          </svg>
          {m.learning_path_foundation_label()}
        </div>
      </div>

      <!-- Foundation Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl mx-auto">
        <!-- Scratch Card -->
        <div class="group relative bg-[#F0FAF2] border border-[#1D8536]/20 rounded-2xl p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-center gap-4 mb-3">
            <div class="w-12 h-12 rounded-xl bg-[#1D8536] flex items-center justify-center shadow-lg shadow-[#1D8536]/30 group-hover:scale-110 transition-transform duration-300 shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6"/>
                <polyline points="8 6 2 12 8 18"/>
              </svg>
            </div>
            <h4 class="font-bold text-[#1A1A1A] text-base leading-snug" style="font-family: 'Sora', sans-serif;">
              {m.learning_path_1_title()}
            </h4>
          </div>
          <p class="text-sm text-[#6B7280] leading-relaxed">
            {m.learning_path_1_desc()}
          </p>
        </div>

        <!-- Electronics Card -->
        <div class="group relative bg-[#FFF8F0] border border-[#E18914]/30 rounded-2xl p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <!-- NEW Badge -->
          <div class="absolute -top-2.5 -right-2.5 bg-[#E18914] text-white text-[10px] font-extrabold uppercase tracking-wider px-2.5 py-1 rounded-full shadow-lg shadow-[#E18914]/40 z-10">
            {m.learning_path_electronics_new()}
          </div>
          <!-- FREE Badge -->
          <div class="absolute -top-2.5 right-14 bg-[#1D8536] text-white text-[10px] font-extrabold uppercase tracking-wider px-2.5 py-1 rounded-full shadow-lg shadow-[#1D8536]/40 z-10">
            {m.learning_path_electronics_free()}
          </div>
          <div class="flex items-center gap-4 mb-3">
            <div class="w-12 h-12 rounded-xl bg-[#E18914] flex items-center justify-center shadow-lg shadow-[#E18914]/30 group-hover:scale-110 transition-transform duration-300 shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v6l3-3"/>
                <path d="M12 2v6l-3-3"/>
                <circle cx="12" cy="14" r="4"/>
                <path d="M8 14H2M22 14h-6"/>
              </svg>
            </div>
            <h4 class="font-bold text-[#1A1A1A] text-base leading-snug" style="font-family: 'Sora', sans-serif;">
              {m.learning_path_electronics_title()}
            </h4>
          </div>
          <p class="text-sm text-[#6B7280] leading-relaxed">
            {m.learning_path_electronics_desc()}
          </p>
        </div>
      </div>
    </div>

    <!-- ===== SVG FORK DIAGRAM ===== -->
    <div class="relative flex justify-center my-2" style="height: 80px;">
      <!-- Desktop SVG fork -->
      <svg class="hidden md:block w-full max-w-3xl" viewBox="0 0 700 80" fill="none" preserveAspectRatio="xMidYMid meet" style="height: 80px;">
        <!-- Center vertical line down from foundation -->
        <line x1="350" y1="0" x2="350" y2="20" stroke="#1D8536" stroke-width="2.5" stroke-linecap="round"/>
        <!-- Dot at fork point -->
        <circle cx="350" cy="20" r="5" fill="#1D8536"/>
        <!-- Left branch curve to Coding -->
        <path d="M350 20 C350 35, 175 35, 175 55 L175 80" stroke="#F9DB2B" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <!-- Right branch curve to Electronics -->
        <path d="M350 20 C350 35, 525 35, 525 55 L525 80" stroke="#E18914" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <!-- Left endpoint dot -->
        <circle cx="175" cy="80" r="5" fill="#F9DB2B"/>
        <!-- Right endpoint dot -->
        <circle cx="525" cy="80" r="5" fill="#E18914"/>
        <!-- Coding label -->
        <text x="175" y="52" text-anchor="middle" fill="#B89E00" font-size="10" font-weight="700" letter-spacing="0.1em" font-family="Sora, sans-serif">CODING</text>
        <!-- Electronics label -->
        <text x="525" y="52" text-anchor="middle" fill="#E18914" font-size="10" font-weight="700" letter-spacing="0.1em" font-family="Sora, sans-serif">ELECTRONICS</text>
      </svg>

      <!-- Mobile: simple vertical connector -->
      <div class="md:hidden flex flex-col items-center gap-1 py-2">
        <div class="w-0.5 h-4 bg-[#1D8536]"></div>
        <div class="w-3 h-3 rounded-full bg-[#1D8536]"></div>
        <svg width="80" height="40" viewBox="0 0 80 40" fill="none">
          <path d="M40 0 C40 10, 20 20, 20 30" stroke="#F9DB2B" stroke-width="2" fill="none" stroke-linecap="round"/>
          <path d="M40 0 C40 10, 60 20, 60 30" stroke="#E18914" stroke-width="2" fill="none" stroke-linecap="round"/>
        </svg>
      </div>
    </div>

    <!-- ===== TRACK CARDS (Side by Side) ===== -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">

      <!-- ====== CODING TRACK (Left / Yellow) ====== -->
      <div class="group bg-white border-2 border-[#F9DB2B]/30 rounded-2xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <!-- Track Header -->
        <div class="bg-gradient-to-r from-[#F9DB2B] to-[#FFEB6B] px-6 py-4 flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-white/30 flex items-center justify-center backdrop-blur-sm">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/>
              <polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <div>
            <div class="text-[10px] font-bold text-[#1A1A1A]/60 uppercase tracking-[0.15em]">Track</div>
            <h3 class="font-bold text-[#1A1A1A] text-lg leading-tight" style="font-family: 'Sora', sans-serif;">
              {m.learning_path_coding_label()}
            </h3>
          </div>
        </div>

        <!-- Steps -->
        <div class="p-6 space-y-4">
          <!-- Step 2: MakeCode IoT -->
          <div class="flex items-start gap-4 group/step">
            <div class="relative shrink-0">
              <div class="w-11 h-11 rounded-xl bg-[#F9DB2B]/15 flex items-center justify-center border border-[#F9DB2B]/30 group-hover/step:scale-110 transition-transform duration-300">
                <span class="text-lg font-black text-[#B89E00]" style="font-family: 'Sora', sans-serif;">1</span>
              </div>
            </div>
            <div class="flex-1 pt-0.5">
              <h5 class="font-bold text-[#1A1A1A] text-sm mb-1 leading-snug" style="font-family: 'Sora', sans-serif;">
                {m.learning_path_2_title()}
              </h5>
              <p class="text-xs text-[#6B7280] leading-relaxed">
                {m.learning_path_2_desc()}
              </p>
            </div>
          </div>

          <!-- Connector dot-line between steps -->
          <div class="flex justify-center">
            <div class="w-0.5 h-5 bg-[#F9DB2B]/40 rounded-full"></div>
          </div>

          <!-- Step 4: Advanced Projects -->
          <div class="flex items-start gap-4 group/step">
            <div class="relative shrink-0">
              <div class="w-11 h-11 rounded-xl bg-[#1A1A1A] flex items-center justify-center shadow-lg shadow-black/20 group-hover/step:scale-110 transition-transform duration-300">
                <span class="text-lg font-black text-white" style="font-family: 'Sora', sans-serif;">2</span>
              </div>
              <div class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-white border-2 border-[#1A1A1A] flex items-center justify-center">
                <svg width="6" height="6" viewBox="0 0 8 8" fill="none" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round">
                  <path d="M1 4l2 2 4-4"/>
                </svg>
              </div>
            </div>
            <div class="flex-1 pt-0.5">
              <h5 class="font-bold text-[#1A1A1A] text-sm mb-1 leading-snug" style="font-family: 'Sora', sans-serif;">
                {m.learning_path_4_title()}
              </h5>
              <p class="text-xs text-[#6B7280] leading-relaxed">
                {m.learning_path_4_desc()}
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- ====== ELECTRONICS TRACK (Right / Orange) ====== -->
      <div class="group bg-white border-2 border-[#E18914]/30 rounded-2xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <!-- Track Header -->
        <div class="bg-gradient-to-r from-[#E18914] to-[#F5A623] px-6 py-4 flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-white/30 flex items-center justify-center backdrop-blur-sm">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="4" width="16" height="16" rx="2"/>
              <path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3"/>
            </svg>
          </div>
          <div>
            <div class="text-[10px] font-bold text-[#1A1A1A]/60 uppercase tracking-[0.15em]">Track</div>
            <h3 class="font-bold text-[#1A1A1A] text-lg leading-tight" style="font-family: 'Sora', sans-serif;">
              {m.learning_path_robotics_label()}
            </h3>
          </div>
        </div>

        <!-- Steps -->
        <div class="p-6 space-y-4">
          <!-- Step 3: Arduino Virtual -->
          <div class="flex items-start gap-4 group/step">
            <div class="relative shrink-0">
              <div class="w-11 h-11 rounded-xl bg-[#E18914]/15 flex items-center justify-center border border-[#E18914]/30 group-hover/step:scale-110 transition-transform duration-300">
                <span class="text-lg font-black text-[#E18914]" style="font-family: 'Sora', sans-serif;">1</span>
              </div>
            </div>
            <div class="flex-1 pt-0.5">
              <h5 class="font-bold text-[#1A1A1A] text-sm mb-1 leading-snug" style="font-family: 'Sora', sans-serif;">
                {m.learning_path_3_title()}
              </h5>
              <p class="text-xs text-[#6B7280] leading-relaxed">
                {m.learning_path_3_desc()}
              </p>
            </div>
          </div>

          <!-- Connector dot-line between steps -->
          <div class="flex justify-center">
            <div class="w-0.5 h-5 bg-[#E18914]/40 rounded-full"></div>
          </div>

          <!-- Step 4: Real-World Hardware -->
          <div class="flex items-start gap-4 group/step">
            <div class="relative shrink-0">
              <div class="w-11 h-11 rounded-xl bg-[#1A1A1A] flex items-center justify-center shadow-lg shadow-black/20 group-hover/step:scale-110 transition-transform duration-300">
                <span class="text-lg font-black text-white" style="font-family: 'Sora', sans-serif;">2</span>
              </div>
              <div class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-white border-2 border-[#1A1A1A] flex items-center justify-center">
                <svg width="6" height="6" viewBox="0 0 8 8" fill="none" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round">
                  <path d="M1 4l2 2 4-4"/>
                </svg>
              </div>
            </div>
            <div class="flex-1 pt-0.5">
              <h5 class="font-bold text-[#1A1A1A] text-sm mb-1 leading-snug" style="font-family: 'Sora', sans-serif;">
                {m.learning_path_4_title()}
              </h5>
              <p class="text-xs text-[#6B7280] leading-relaxed">
                {m.learning_path_4_desc()}
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Sora:wght@700;800;900&display=swap');
</style>
