---
import { Zap, Code, Brain, ArrowRight, BookOpen } from '@lucide/astro';
import { m } from '../../paraglide/messages.js';
import { LMS_URL } from '../../lib/config.js';

const codingPath = [
  { 
    num: '1', 
    title: m.learning_path_1_title(), 
    desc: m.learning_path_1_desc(), 
    deliverable: m.learning_path_1_deliverable(),
  },
  { 
    num: '2', 
    title: m.learning_path_2_title(), 
    desc: m.learning_path_2_desc(), 
    deliverable: m.learning_path_2_deliverable(),
  },
  { 
    num: '3', 
    title: m.learning_path_3_title(), 
    desc: m.learning_path_3_desc(), 
    deliverable: m.learning_path_3_deliverable(),
  },
];

const electronicsPath = [
  { 
    num: '1', 
    title: m.learning_path_electronics_title(), 
    desc: m.learning_path_electronics_desc(), 
    deliverable: "5 circuit experiments",
    badge: m.learning_path_electronics_free(),
    badgeColor: "#1D8536"
  },
  { 
    num: '2', 
    title: m.learning_path_3_title(), 
    desc: m.learning_path_3_desc(), 
    deliverable: m.learning_path_3_deliverable(),
  },
];

const aiPath = [
  { 
    num: '1', 
    title: m.tm_title(), 
    desc: m.tm_subtitle(), 
    deliverable: "Image, Sound & Pose recognition",
    badge: m.learning_path_electronics_free(),
    badgeColor: "#8B5CF6"
  },
];
---

<section class="py-20 lg:py-28 bg-white overflow-hidden" id="curriculum">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 bg-[#F9DB2B]/15 text-[#B89E00] text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-5">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M6 0l1.5 4.5H12L8.25 7.25 9.75 12 6 9.25 2.25 12l1.5-4.75L0 4.5h4.5z"/></svg>
        {m.learning_path_badge()}
      </div>
      <h2 class="text-2xl sm:text-3xl font-bold text-[#2D2D2D] leading-tight mb-3">
        {m.learning_path_title()}
      </h2>
      <p class="text-[#6B7280] text-base sm:text-lg max-w-2xl mx-auto">
        {m.learning_path_subtitle()}
      </p>
    </div>

    <!-- Three Paths -->
    <div class="grid lg:grid-cols-3 gap-6 lg:gap-8">
      
      <!-- Coding Path -->
      <div class="bg-gradient-to-br from-[#F3F4F6] to-white rounded-3xl p-5 lg:p-6 border border-gray-100">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-full bg-[#E18914]/10 flex items-center justify-center">
            <Code size={18} class="text-[#E18914]" />
          </div>
          <div>
            <h3 class="text-base font-bold text-[#2D2D2D]">{m.learning_path_coding_path()}</h3>
            <p class="text-[10px] text-[#6B7280]">Visual programming</p>
          </div>
        </div>
        
        <div class="space-y-3">
          {codingPath.map((step, index) => (
            <div class="flex gap-3">
              <div class="flex flex-col items-center">
                <div class={`w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white ${index === 0 ? 'bg-[#1D8536]' : index === 1 ? 'bg-[#F9DB2B] text-[#2D2D2D]' : 'bg-[#E18914]'}`}>
                  {step.num}
                </div>
                {index < codingPath.length - 1 && (
                  <div class="w-0.5 h-6 bg-gray-200 mt-1"></div>
                )}
              </div>
              <div class="flex-1 pb-3">
                <h4 class="text-sm font-bold text-[#2D2D2D] mb-1">{step.title}</h4>
                <p class="text-xs text-[#6B7280] mb-2 line-clamp-2">{step.desc}</p>
                <span class="text-[10px] bg-[#E18914]/10 px-2 py-0.5 rounded-full text-[#E18914]">{step.deliverable}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Electronics Path -->
      <div class="bg-gradient-to-br from-[#F3F4F6] to-white rounded-3xl p-5 lg:p-6 border border-gray-100">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-full bg-[#1D8536]/10 flex items-center justify-center">
            <Zap size={18} class="text-[#1D8536]" />
          </div>
          <div>
            <h3 class="text-base font-bold text-[#2D2D2D]">{m.learning_path_electronics_path()}</h3>
            <p class="text-[10px] text-[#6B7280]">Circuit fundamentals</p>
          </div>
        </div>
        
        <div class="space-y-3">
          {electronicsPath.map((step, index) => (
            <div class="flex gap-3">
              <div class="flex flex-col items-center">
                <div class={`w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white ${step.badgeColor}`}>
                  {step.num}
                </div>
                {index < electronicsPath.length - 1 && (
                  <div class="w-0.5 h-6 bg-gray-200 mt-1"></div>
                )}
              </div>
              <div class="flex-1 pb-3">
                <div class="flex items-center gap-2 mb-1">
                  <h4 class="text-sm font-bold text-[#2D2D2D]">{step.title}</h4>
                  {step.badge && (
                    <span class={`text-[9px] font-bold px-1.5 py-0.5 rounded-full text-white`} style={`background-color: ${step.badgeColor}`}>
                      {step.badge}
                    </span>
                  )}
                </div>
                <p class="text-xs text-[#6B7280] mb-2 line-clamp-2">{step.desc}</p>
                <span class="text-[10px] bg-[#1D8536]/10 px-2 py-0.5 rounded-full text-[#1D8536]">{step.deliverable}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- AI / Teachable Machine Path -->
      <div class="bg-gradient-to-br from-[#F3F4F6] to-white rounded-3xl p-5 lg:p-6 border border-gray-100">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-full bg-[#8B5CF6]/10 flex items-center justify-center">
            <Brain size={18} class="text-[#8B5CF6]" />
          </div>
          <div>
            <h3 class="text-base font-bold text-[#2D2D2D]">AI & Machine Learning</h3>
            <p class="text-[10px] text-[#6B7280]">No code required</p>
          </div>
        </div>
        
        <div class="space-y-3">
          {aiPath.map((step, index) => (
            <div class="flex gap-3">
              <div class="flex flex-col items-center">
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white bg-[#8B5CF6]">
                  AI
                </div>
              </div>
              <div class="flex-1 pb-3">
                <div class="flex items-center gap-2 mb-1">
                  <h4 class="text-sm font-bold text-[#2D2D2D]">{step.title}</h4>
                  <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full text-white bg-[#8B5CF6]">
                    {step.badge}
                  </span>
                </div>
                <p class="text-xs text-[#6B7280] mb-2 line-clamp-2">{step.desc}</p>
                <span class="text-[10px] bg-[#8B5CF6]/10 px-2 py-0.5 rounded-full text-[#8B5CF6]">{step.deliverable}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Convergence Note -->
    <div class="mt-10 text-center">
      <p class="text-sm text-[#6B7280]">
        <span class="font-semibold text-[#2D2D2D]">All paths lead to real-world skills.</span> Kids can start with any track based on their interest — coding, electronics, or AI. They can also take all!
      </p>
    </div>

    <!-- CTA -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
      <a
        href={`${LMS_URL}/register`}
        class="w-full sm:w-auto flex items-center justify-center gap-2 bg-[#E18914] hover:bg-[#c9780f] text-white px-8 py-4 rounded-full text-lg font-bold transition-all hover:shadow-xl hover:shadow-[#E18914]/30 hover:-translate-y-1"
      >
        {m.hero_cta_register()} <ArrowRight size={20} />
      </a>
      <a
        href="#pricing"
        class="w-full sm:w-auto flex items-center justify-center gap-2 bg-white hover:bg-[#F3F4F6] text-[#2D2D2D] border border-gray-200 px-8 py-4 rounded-full text-lg font-bold transition-all hover:-translate-y-1"
      >
        <BookOpen size={20} />
        {m.pricing_per_course_title()}
      </a>
    </div>

  </div>
</section>