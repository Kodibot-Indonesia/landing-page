---
import { m } from '../../paraglide/messages.js';
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-bold text-[#2D2D2D] font-sans mb-4">
      {m.learning_path_title()}
    </h2>
    <p class="text-[#6B7280] mb-16 max-w-2xl mx-auto">
      {m.learning_path_subtitle()}
    </p>

    <div class="grid md:grid-cols-4 gap-4 relative">
      <div class="hidden md:block absolute top-[6.5rem] left-0 right-0 h-1 bg-[#F3F4F6] -z-10" />

      <div class="pt-8 relative">
        <div class="w-8 h-8 rounded-full bg-[#F9DB2B] text-white font-bold flex items-center justify-center absolute top-24 left-1/2 -translate-x-1/2 -translate-y-1/2 border-4 border-white z-10 shadow-sm">1</div>
        <div class="bg-[#F3F4F6] rounded-2xl p-6 h-full border border-gray-100 mt-20 hover:-translate-y-2 transition-transform">
          <h4 class="font-bold text-[#2D2D2D] text-lg mb-2">{m.learning_path_1_title()}</h4>
          <p class="text-sm text-[#6B7280]">{m.learning_path_1_desc()}</p>
        </div>
      </div>
      <div class="pt-8 relative">
        <div class="w-8 h-8 rounded-full bg-[#1D8536] text-white font-bold flex items-center justify-center absolute top-24 left-1/2 -translate-x-1/2 -translate-y-1/2 border-4 border-white z-10 shadow-sm">2</div>
        <div class="bg-[#F3F4F6] rounded-2xl p-6 h-full border border-gray-100 mt-20 hover:-translate-y-2 transition-transform">
          <h4 class="font-bold text-[#2D2D2D] text-lg mb-2">{m.learning_path_2_title()}</h4>
          <p class="text-sm text-[#6B7280]">{m.learning_path_2_desc()}</p>
        </div>
      </div>
      <div class="pt-8 relative">
        <div class="w-8 h-8 rounded-full bg-[#E18914] text-white font-bold flex items-center justify-center absolute top-24 left-1/2 -translate-x-1/2 -translate-y-1/2 border-4 border-white z-10 shadow-sm">3</div>
        <div class="bg-[#E18914]/10 rounded-2xl p-6 h-full border border-[#E18914]/30 mt-20 hover:-translate-y-2 transition-transform">
          <h4 class="font-bold text-[#E18914] text-lg mb-2">{m.learning_path_3_title()}</h4>
          <p class="text-sm text-[#E18914]/80">{m.learning_path_3_desc()}</p>
        </div>
      </div>
      <div class="pt-8 relative">
        <div class="w-8 h-8 rounded-full bg-[#2D2D2D] text-white font-bold flex items-center justify-center absolute top-24 left-1/2 -translate-x-1/2 -translate-y-1/2 border-4 border-white z-10 shadow-sm">4</div>
        <div class="bg-[#2D2D2D] rounded-2xl p-6 h-full border border-gray-100 mt-20 hover:-translate-y-2 transition-transform">
          <h4 class="font-bold text-white text-lg mb-2">{m.learning_path_4_title()}</h4>
          <p class="text-sm text-gray-400">{m.learning_path_4_desc()}</p>
        </div>
      </div>
    </div>
  </div>
</section>
