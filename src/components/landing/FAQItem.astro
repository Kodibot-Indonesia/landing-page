---
interface Props {
  question: string;
  answer: string;
}
const { question, answer } = Astro.props;
---

<details class="group border border-gray-200 rounded-2xl overflow-hidden bg-white hover:border-[#E18914]/50 transition-colors">
  <summary class="w-full text-left px-6 py-5 flex items-center justify-between cursor-pointer list-none focus:outline-none [&::-webkit-details-marker]:hidden">
    <h3 class="text-lg font-bold text-[#2D2D2D] pr-8">{question}</h3>
    <svg class="w-5 h-5 text-[#E18914] transform transition-transform duration-300 group-open:rotate-180 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>
  <div class="px-6 pb-5">
    <p class="text-[#6B7280] leading-relaxed">{answer}</p>
  </div>
</details>
