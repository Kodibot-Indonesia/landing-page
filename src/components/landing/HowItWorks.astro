---
import { BookOpen, Gamepad2, Trophy } from '@lucide/astro';
import { m } from '../../paraglide/messages.js';
---

<section class="py-24 bg-[#F3F4F6]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-[#2D2D2D] font-sans mb-4">
        {m.how_it_works_title()}
      </h2>
      <p class="text-[#6B7280] max-w-2xl mx-auto">
        {m.how_it_works_subtitle()}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 relative">
      <div class="hidden md:block absolute top-12 left-[15%] right-[15%] h-0.5 bg-gray-200" />

      <div class="relative flex flex-col items-center text-center">
        <div class="w-24 h-24 bg-white border-4 border-[#F3F4F6] shadow-xl rounded-full flex items-center justify-center mb-6 z-10">
          <BookOpen size={40} class="text-[#E18914]" />
        </div>
        <h3 class="text-2xl font-bold text-[#2D2D2D] mb-3">{m.how_it_works_step1_title()}</h3>
        <p class="text-[#6B7280]">{m.how_it_works_step1_desc()}</p>
      </div>

      <div class="relative flex flex-col items-center text-center">
        <div class="w-24 h-24 bg-[#E18914] border-4 border-[#F3F4F6] shadow-xl shadow-[#E18914]/30 rounded-full flex items-center justify-center mb-6 z-10 text-white">
          <Gamepad2 size={40} />
        </div>
        <h3 class="text-2xl font-bold text-[#2D2D2D] mb-3">{m.how_it_works_step2_title()}</h3>
        <p class="text-[#6B7280]">{m.how_it_works_step2_desc()}</p>
      </div>

      <div class="relative flex flex-col items-center text-center">
        <div class="w-24 h-24 bg-white border-4 border-[#F3F4F6] shadow-xl rounded-full flex items-center justify-center mb-6 z-10">
          <Trophy size={40} class="text-[#1D8536]" />
        </div>
        <h3 class="text-2xl font-bold text-[#2D2D2D] mb-3">{m.how_it_works_step3_title()}</h3>
        <p class="text-[#6B7280]">{m.how_it_works_step3_desc()}</p>
      </div>
    </div>
  </div>
</section>
