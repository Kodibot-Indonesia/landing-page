---
import { locales } from '../../paraglide/runtime.js';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Hero from '../../components/landing/Hero.astro';
import Problem from '../../components/landing/Problem.astro';
import Solution from '../../components/landing/Solution.astro';
import CircuitLab from '../../components/landing/CircuitLab.astro';
import LearningPath from '../../components/landing/LearningPath.astro';
import Comparison from '../../components/landing/Comparison.astro';
import SocialProof from '../../components/landing/SocialProof.astro';
import Pricing from '../../components/landing/Pricing.astro';
import FAQ from '../../components/landing/FAQ.astro';
import CTA from '../../components/landing/CTA.astro';
import Footer from '../../components/landing/Footer.astro';
import WhatsAppFloating from '../../components/landing/WhatsAppFloating.astro';
import { m } from '../../paraglide/messages.js';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const lang = locale || 'en';
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://kodibot.id';
const canonicalURL = `${siteUrl}/${lang}/`;
const hreflangAlternates = locales.map((l) => ({
  locale: l,
  url: l === 'en' ? `${siteUrl}/` : `${siteUrl}/${l}/`,
}));
const faqItems = [
  { question: m.faq_q1(), answer: m.faq_a1() },
  { question: m.faq_q2(), answer: m.faq_a2() },
  { question: m.faq_q3(), answer: m.faq_a3() },
  { question: m.faq_q4(), answer: m.faq_a4() },
  { question: m.faq_q5(), answer: m.faq_a5() },
];
---

<Layout title={m.meta_title()} description={m.meta_description()} lang={lang} canonicalURL={canonicalURL} hreflangAlternates={hreflangAlternates} faqItems={faqItems}>
  <div class="min-h-screen bg-[#F3F4F6] font-sans selection:bg-[#F9DB2B]/30 selection:text-[#2D2D2D]">
    <Nav currentLocale={lang} />
    <Hero />
    <Problem />
    <Solution />
    <CircuitLab />
    <LearningPath />
    <Comparison />
    <SocialProof />
    <Pricing />
    <FAQ />
    <CTA />
    <Footer currentLocale={lang} />
    <WhatsAppFloating />
  </div>
</Layout>
