---
import { locales } from '../../paraglide/runtime.js';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import PostCard from '../../components/blog/PostCard.astro';
import SearchBar from '../../components/blog/SearchBar.astro';
import CategoryFilter from '../../components/blog/CategoryFilter.astro';
import Pagination from '../../components/blog/Pagination.astro';
import WhatsAppFloating from '../../components/landing/WhatsAppFloating.astro';

const lang = 'en';
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://kodibot.id';

// Get query params
const url = new URL(Astro.url);
const currentPage = parseInt(url.searchParams.get('page') || '1');
const categoryFilter = url.searchParams.get('category') || '';
const searchQuery = url.searchParams.get('q') || '';
const postsPerPage = 6;

// Get all blog posts for English
const allPosts = await getCollection('blog', ({ id }) => {
  return id.startsWith(`${lang}/`);
});

// Sort by date, filter out drafts
const localePosts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get unique categories
const allCategories = [...new Set(localePosts.map((post) => post.data.category))];

// Filter by category
let filteredPosts = localePosts;
if (categoryFilter) {
  filteredPosts = filteredPosts.filter((post) => post.data.category === categoryFilter);
}

// Calculate pagination
const totalPages = Math.ceil(filteredPosts.length / postsPerPage);
const startIndex = (currentPage - 1) * postsPerPage;
const paginatedPosts = filteredPosts.slice(startIndex, startIndex + postsPerPage);

const canonicalURL = `${siteUrl}/blog/`;
const hreflangAlternates = locales.map((l) => ({
  locale: l,
  url: l === 'en' ? `${siteUrl}/blog/` : `${siteUrl}/${l}/blog/`,
}));

const blogBaseUrl = '/blog';

const pageTitle = 'Coding & STEM Tips for Kids';
const pageDescription = 'Articles about coding education, Arduino, and STEM for kids aged 8-15. Parenting tips and programming tutorials.';
const no_results = 'No articles found.';
---

<Layout title={`${pageTitle} | Kodibot Blog`} description={pageDescription} lang={lang} canonicalURL={canonicalURL} hreflangAlternates={hreflangAlternates}>
  <div class="min-h-screen bg-[#F3F4F6] font-sans selection:bg-[#F9DB2B]/30 selection:text-[#2D2D2D]">
    <Nav currentLocale={lang} />
    
    <!-- Hero Section -->
    <section class="pt-32 pb-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#F9DB2B]/20 border border-[#F9DB2B]/30 text-[#B89E00] font-medium text-sm mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"></path>
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
            </svg>
            <span>Kodibot Blog</span>
          </div>
          <h1 class="text-4xl lg:text-5xl font-bold text-[#2D2D2D] font-sans mb-4">
            {pageTitle}
          </h1>
          <p class="text-xl text-[#6B7280] max-w-2xl mx-auto">
            {pageDescription}
          </p>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-12 px-4">
      <div class="max-w-7xl mx-auto">
        {/* Search and Filter */}
        <div class="flex flex-col lg:flex-row gap-4 mb-8">
          <div class="flex-1">
            <SearchBar placeholder="Search articles..." currentValue={searchQuery} />
          </div>
        </div>

        {/* Category Filter */}
        <div class="mb-8">
          <CategoryFilter categories={allCategories} currentCategory={categoryFilter} allLabel="All" locale={lang} />
        </div>

        {/* Blog Grid */}
        {paginatedPosts.length > 0 ? (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {paginatedPosts.map((post) => {
              const slug = post.id.replace(`${lang}/`, '');
              return (
                <div
                  data-blog-card
                  data-title={post.data.title}
                  data-description={post.data.description}
                  data-category={post.data.category}
                  data-tags={post.data.tags?.join(',') || ''}
                >
                  <PostCard
                    title={post.data.title}
                    description={post.data.description}
                    pubDate={post.data.pubDate}
                    heroImage={post.data.heroImage}
                    author={post.data.author}
                    category={post.data.category}
                    tags={post.data.tags}
                    slug={slug}
                    locale={lang}
                  />
                </div>
              );
            })}
          </div>
        ) : (
          <div class="text-center py-16">
            <p class="text-gray-500 text-lg">{no_results}</p>
          </div>
        )}

        {/* No Results Message (hidden by default) */}
        <div id="no-results" class="hidden text-center py-12">
          <p class="text-gray-500 text-lg">{no_results}</p>
        </div>

        {/* Pagination */}
        <div class="mt-12">
          <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl={blogBaseUrl} />
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 bg-[#1D8536]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">
          Ready to Start Learning?
        </h2>
        <p class="text-white/80 mb-8">
          Try 7 days free and watch your child become a tech creator
        </p>
        <a
          href="https://app.kodibot.id/register"
          class="inline-flex items-center gap-2 bg-[#E18914] hover:bg-[#F9DB2B] hover:text-[#2D2D2D] text-white px-8 py-4 rounded-full text-lg font-bold transition-all"
        >
          Start Free Trial
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </section>

    <Footer currentLocale={lang} />
    <WhatsAppFloating />
  </div>
</Layout>
