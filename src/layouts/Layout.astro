---
interface Props {
  title?: string;
  description?: string;
  lang?: string;
  canonicalURL?: string;
  hreflangAlternates?: { locale: string; url: string }[];
  faqItems?: { question: string; answer: string }[];
  courses?: { name: string; description: string; position: number }[];
  products?: { name: string; price: string; priceCurrency: string; description: string }[];
  breadcrumbs?: { name: string; url: string }[];
}

const {
  title = "KODIBOT – Coding & STEM Learning Platform for Kids",
  description = "Learn coding and Arduino from scratch with interactive simulator. No hardware purchase needed. Try free now.",
  lang = "en",
  canonicalURL,
  hreflangAlternates,
  faqItems,
  courses = [
    { name: "Scratch Basics", description: "Learn looping, conditions, and variables through games and animations.", position: 1 },
    { name: "MakeCode IoT", description: "Transition from screen to virtual physical devices. Sensor and Micro:bit interaction.", position: 2 },
    { name: "Arduino Virtual", description: "Build circuits, breadboard, and structured C++ programming via visual blocks.", position: 3 },
    { name: "Real-World Projects", description: "Ready for real hardware. Implement on physical Arduino without fear.", position: 4 },
  ],
  products = [
    { name: "Monthly Plan", price: "99000", priceCurrency: "IDR", description: "30 days access to all curriculum" },
    { name: "3 Months Plan", price: "149000", priceCurrency: "IDR", description: "90 days access to all curriculum" },
    { name: "Founding Member", price: "349000", priceCurrency: "IDR", description: "Lifetime access to all curriculum" },
  ],
  breadcrumbs = [{ name: "Home", url: "/" }],
} = Astro.props;
const siteUrl =
  Astro.site?.toString().replace(/\/$/, "") || "https://kodibot.id";
const url = canonicalURL || new URL(Astro.url.pathname, siteUrl).toString();

// Generate search params for the OG Image
const searchParams = new URLSearchParams();
searchParams.set("title", title);
searchParams.set("desc", description);
const ogImage = `${siteUrl}/og.png?${searchParams.toString()}`;

const hreflangMap: Record<string, string> = {
  en: "en-US",
  id: "id-ID",
  ms: "ms-MY",
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <script is:inline define:vars={{ lang }}>
      (function () {
        var LOCALE_COOKIE = "locale_preferred";
        var path = window.location.pathname;
        var referrer = document.referrer || "";
        var cameFromLocalePage = /\/(id|ms)(\/|$)/.test(referrer);

        // Only run detection on root path or when coming from external links
        if (path !== "/" && !cameFromLocalePage) {
          if (lang) {
            document.cookie =
              LOCALE_COOKIE +
              "=" +
              lang +
              ";path=/;max-age=31536000;samesite=lax";
          }
          return;
        }

        // Save current locale preference from rendered page
        if (lang) {
          document.cookie =
            LOCALE_COOKIE + "=" + lang + ";path=/;max-age=31536000;samesite=lax";
        }

        // If user is already on a non-default locale page, no need to redirect
        if (/^(\/id|\/ms)/.test(path)) {
          return;
        }

        // Check if user has a saved preference
        var cookie = document.cookie.match(
          new RegExp(LOCALE_COOKIE + "=([^;]+)"),
        );
        var preferred = cookie ? cookie[1].toLowerCase() : null;

        // If user has saved preference for id or ms, redirect them
        if (preferred === "id" || preferred === "ms") {
          window.location.replace("/" + preferred + "/");
          return;
        }

        // If user has no saved preference yet, fall back to browser language
        if (!preferred) {
          var navLang = (navigator.language || navigator.userLanguage || "")
            .toLowerCase()
            .split("-")[0];

          if (navLang === "id" || navLang === "ms") {
            document.cookie =
              LOCALE_COOKIE +
              "=" +
              navLang +
              ";path=/;max-age=31536000;samesite=lax";
            window.location.replace("/" + navLang + "/");
          } else {
            document.cookie =
              LOCALE_COOKIE + "=en;path=/;max-age=31536000;samesite=lax";
          }
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Kodibot" />
    <meta name="geo.region" content="ID" />
    <meta name="geo.placename" content="Indonesia" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link
      rel="icon"
      type="image/png"
      sizes="96x96"
      href="/favicon/favicon-96x96.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <link rel="manifest" href="/favicon/site.webmanifest" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="kids coding, online coding course for kids, Arduino for kids, STEM platform for kids, coding for beginners kids"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta
      property="og:locale"
      content={lang === "id" ? "id_ID" : lang === "ms" ? "ms_MY" : "en_US"}
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:domain" content={new URL(siteUrl).hostname} />
    <meta name="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="theme-color" content="#F9DB2B" />

    <!-- Canonical -->
    <link rel="canonical" href={url} />

    <!-- hreflang -->
    {
      hreflangAlternates?.map((alt) => (
        <link
          rel="alternate"
          hreflang={hreflangMap[alt.locale] || alt.locale}
          href={alt.url}
        />
      ))
    }
    {
      hreflangAlternates && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={hreflangAlternates.find((a) => a.locale === "en")?.url || url}
        />
      )
    }

    <!-- JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            name: "Kodibot",
            url: siteUrl,
            logo: `${siteUrl}/favicon/web-app-manifest-512x512.png`,
            contactPoint: {
              "@type": "ContactPoint",
              contactType: "customer service",
              availableLanguage: ["Indonesian", "English"],
            },
          },
          {
            "@type": "WebSite",
            name: "Kodibot",
            url: siteUrl,
            inLanguage: lang,
            potentialAction: {
              "@type": "SearchAction",
              target: {
                "@type": "EntryPoint",
                urlTemplate: `${siteUrl}/search?q={search_term_string}`,
              },
              "query-input": "required name=search_term_string",
            },
          },
          {
            "@type": "BreadcrumbList",
            itemListElement: breadcrumbs.map((item, i) => ({
              "@type": "ListItem",
              position: i + 1,
              name: item.name,
              item: `${siteUrl}${item.url}`,
            })),
          },
          ...courses.map((course) => ({
            "@type": "Course",
            name: course.name,
            description: course.description,
            provider: {
              "@type": "Organization",
              name: "Kodibot",
              url: siteUrl,
            },
            inLanguage: lang,
            educationalLevel: "Beginner",
            audience: {
              "@type": "Audience",
              audienceType: "Kids 8-15",
            },
          })),
          ...products.map((product) => ({
            "@type": "Product",
            name: product.name,
            description: product.description,
            brand: {
              "@type": "Brand",
              name: "Kodibot",
            },
            offers: {
              "@type": "Offer",
              price: product.price,
              priceCurrency: product.priceCurrency,
              availability: "https://schema.org/InStock",
              seller: {
                "@type": "Organization",
                name: "Kodibot",
              },
            },
          })),
          ...(faqItems && faqItems.length > 0
            ? [
                {
                  "@type": "FAQPage",
                  inLanguage: lang,
                  mainEntity: faqItems.map((item) => ({
                    "@type": "Question",
                    name: item.question,
                    acceptedAnswer: { "@type": "Answer", text: item.answer },
                  })),
                },
              ]
            : []),
        ],
      })}
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
